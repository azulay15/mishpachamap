# Copy to .env.local and fill in.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_YOUR_PUBLISHABLE_KEY
# Server-side only. Never exposed to the client. Used by ingest scripts to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_YOUR_SECRET_KEY

# --- Mapbox ---
NEXT_PUBLIC_MAPBOX_TOKEN=pk.YOUR_MAPBOX_PUBLIC_TOKEN

# --- Anthropic (Phase 3: AI Neighborhood Expert chat) ---
# Get a key at https://console.anthropic.com → Settings → API Keys.
# Server-side only. Never exposed to the client. Used by app/api/chat.
ANTHROPIC_API_KEY=
